---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Divider from '../components/Divider.astro';
import { CHALISA_PDF } from '../site.ts';

const books = [
  { t: 'Be Here Now', a: 'Ram Dass', d: 'The seminal account of meeting Maharaj-ji and the turn toward the heart.' },
  { t: 'Miracle of Love', a: 'Ram Dass', d: 'Hundreds of stories of Neem Karoli Baba, gathered from his devotees.' },
  { t: 'Chants of a Lifetime', a: 'Krishna Das', d: 'On kirtan, grief, and finding the guru through the divine names.' },
  { t: 'By His Grace', a: 'Dada Mukerjee', d: 'An intimate memoir by a close Indian devotee of Maharaj-ji.' },
];

const listen = [
  { t: 'Here and Now — Ram Dass', d: 'The long-running podcast of Ram Dass’s talks.', href: 'https://beherenownetwork.com/category/ram-dass-here-and-now/' },
  { t: 'Krishna Das — kirtan', d: 'Albums and chants to sing along with.', href: 'https://www.krishnadas.com/music/' },
  { t: 'Love Serve Remember Foundation', d: 'Talks, guided meditations & writings.', href: 'https://www.ramdass.org/' },
];

const ashrams = [
  { t: 'Kainchi Dham', loc: 'Nainital, Uttarakhand', d: 'Maharaj-ji’s principal dham. Bhandara each 15 June.', href: 'https://en.wikipedia.org/wiki/Neem_Karoli_Baba' },
  { t: 'Neem Karoli Baba Ashram', loc: 'Taos, New Mexico, USA', d: 'A living ashram with daily aarti, seva & a Hanuman murti.', href: 'https://nkbashram.org/' },
  { t: 'Seva Foundation', loc: 'Berkeley, USA', d: 'Curing preventable blindness — seva in Maharaj-ji’s name.', href: 'https://www.seva.org/' },
];
---

<BaseLayout
  title="Resources"
  description="Books, chants, podcasts and ashrams to go deeper into Neem Karoli Baba, Hanuman bhakti, and the teachings of Ram Dass and Krishna Das."
>
  <PageHero
    eyebrow="To go deeper"
    title="Resources"
    lede="A small, loving shelf — books, chants, talks and dhams to keep you company on the way."
  />

  <!-- chalisa highlight -->
  <section class="shell res-chalisa reveal">
    <div class="rc-card card">
      <div>
        <span class="eyebrow">Sing with us</span>
        <h2 class="deva">श्री हनुमान चालीसा</h2>
        <p>The forty verses we sing each Tuesday. Download a copy to keep and learn.</p>
      </div>
      <a href={CHALISA_PDF} download class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Download (PDF)
      </a>
    </div>
  </section>

  <!-- books -->
  <section class="shell res-block reveal">
    <span class="eyebrow flanked">To read</span>
    <h2>Books</h2>
    <div class="res-grid">
      {books.map((b) => (
        <div class="res-card card">
          <h3>{b.t}</h3>
          <span class="res-by">{b.a}</span>
          <p>{b.d}</p>
        </div>
      ))}
    </div>
  </section>

  <Divider class="res-rule" />

  <!-- listen -->
  <section class="shell res-block reveal">
    <span class="eyebrow flanked">To listen</span>
    <h2>Chants &amp; talks</h2>
    <div class="res-grid res-grid-3">
      {listen.map((l) => (
        <a href={l.href} target="_blank" rel="noopener" class="res-card card is-link">
          <h3>{l.t}</h3>
          <p>{l.d}</p>
          <span class="link-gold">Visit →</span>
        </a>
      ))}
    </div>
  </section>

  <Divider class="res-rule" />

  <!-- ashrams -->
  <section class="shell res-block reveal">
    <span class="eyebrow flanked">Dhams & seva</span>
    <h2>Ashrams in his name</h2>
    <div class="res-grid res-grid-3">
      {ashrams.map((a) => (
        <a href={a.href} target="_blank" rel="noopener" class="res-card card is-link">
          <h3>{a.t}</h3>
          <span class="res-loc">{a.loc}</span>
          <p>{a.d}</p>
          <span class="link-gold">Visit →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .res-chalisa { padding: 1.5rem 0; }
  .rc-card { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; padding: 2.2rem; background: linear-gradient(160deg, color-mix(in srgb, var(--color-saffron) 10%, var(--color-paper-warm)), var(--color-paper-warm)); }
  .rc-card h2 { font-size: 1.8rem; color: var(--color-maroon); margin: 0.3rem 0 0.4rem; }
  .rc-card p { color: var(--color-ink-soft); }

  .res-block { padding: 2rem 0; }
  .res-block > .eyebrow { display: inline-flex; margin-bottom: 0.6rem; }
  .res-block h2 { font-size: clamp(1.6rem, 4vw, 2.3rem); margin-bottom: 1.6rem; }
  .res-grid { display: grid; grid-template-columns: 1fr; gap: 1.3rem; }
  .res-card { padding: 1.7rem; }
  .res-card.is-link { display: flex; flex-direction: column; transition: transform 0.35s var(--ease-soft); }
  .res-card.is-link:hover { transform: translateY(-4px); }
  .res-card h3 { font-size: 1.25rem; color: var(--color-maroon); }
  .res-by { font-family: var(--font-display); font-size: 0.85rem; color: var(--color-saffron-deep); font-style: italic; }
  .res-loc { font-size: 0.8rem; color: var(--color-ink-faint); letter-spacing: 0.04em; }
  .res-card p { color: var(--color-ink-soft); font-size: 0.96rem; margin: 0.5rem 0 0.8rem; flex: 1; }
  .res-rule { margin-block: 1.5rem; }

  @media (min-width: 640px) { .res-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 920px) { .res-grid-3 { grid-template-columns: repeat(3, 1fr); } }
</style>
