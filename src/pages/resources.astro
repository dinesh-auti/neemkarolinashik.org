---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Divider from '../components/Divider.astro';
import { CHALISA_PDF } from '../site.ts';

const books = [
  { t: 'Be Here Now', a: 'Ram Dass', d: 'The seminal account of meeting Maharaj-ji — part teaching, part hand-drawn mandala.' },
  { t: 'Miracle of Love', a: 'Ram Dass', d: 'Hundreds of stories (leelas) of Neem Karoli Baba, gathered from his devotees.' },
  { t: 'By His Grace', a: 'Dada Mukerjee', d: 'An intimate memoir of daily life beside Maharaj-ji.' },
  { t: 'The Near and the Dear', a: 'Dada Mukerjee', d: 'More recollections of life in Baba’s household.' },
  { t: 'Chants of a Lifetime', a: 'Krishna Das', d: 'On kirtan, grief, and finding the guru through the divine names.' },
  { t: 'Love Everyone', a: 'Parvati Markus', d: 'First-person stories from the Western devotees who found Maharaj-ji.' },
];

const watch = [
  { t: 'Ram Dass, Going Home', d: 'A tender late-life portrait of Ram Dass.', href: 'https://www.ramdass.org/' },
  { t: 'Becoming Nobody', d: 'Ram Dass on ego, awareness and letting go.', href: 'https://www.ramdass.org/' },
  { t: 'Fierce Grace', d: 'Ram Dass after his stroke — surrender in real time.', href: 'https://www.ramdass.org/' },
  { t: 'Mevlana / Kainchi footage (1973)', d: 'Rare film of Maharaj-ji’s ashram, via Durgamayi Ma Ashram.', href: 'https://ashram.de/en/neem-karoli-baba' },
];

const listen = [
  { t: 'Here and Now — Ram Dass', d: 'The long-running podcast of Ram Dass’s talks.', href: 'https://beherenownetwork.com/category/ram-dass-here-and-now/' },
  { t: 'Krishna Das — kirtan', d: 'Albums and live chants to sing along with.', href: 'https://www.krishnadas.com/music/' },
  { t: 'Jai Uttal — kirtan', d: 'Ecstatic devotional music in the Maharaj-ji stream.', href: 'https://jaiuttal.com/' },
  { t: 'Be Here Now Network', d: 'A whole network of bhakti & dharma podcasts.', href: 'https://beherenownetwork.com/' },
];

const online = [
  { t: 'Love Serve Remember Foundation', d: 'Ram Dass’s archive — talks, meditations, writings.', href: 'https://www.ramdass.org/' },
  { t: 'Seva Foundation', d: 'Seva in action — curing preventable blindness.', href: 'https://www.seva.org/' },
  { t: 'Neem Karoli Baba Ashram, Taos', d: 'A living ashram with daily aarti & a Hanuman murti.', href: 'https://nkbashram.org/' },
  { t: 'Durgamayi Ma Ashram', d: 'A rich photo & story collection of Maharaj-ji.', href: 'https://ashram.de/en/neem-karoli-baba' },
];
---

<BaseLayout
  title="Resources"
  description="Books, films, kirtan, podcasts and trusted sites to go deeper into Neem Karoli Baba, Hanuman bhakti, Ram Dass and Krishna Das."
>
  <PageHero
    eyebrow="To go deeper"
    title="Resources"
    lede="A small, loving shelf — books, films, chants and dhams to keep you company on the way."
  />

  <!-- chalisa highlight -->
  <section class="shell r-chalisa reveal">
    <div class="rc-card card">
      <div>
        <span class="eyebrow">Sing with us</span>
        <h2 class="deva">श्री हनुमान चालीसा</h2>
        <p>The forty verses we sing each Tuesday — read along, play the audio, or download a copy.</p>
      </div>
      <a href="/chalisa/" class="btn btn-primary">Sing the Chalisa →</a>
    </div>
  </section>

  <section class="shell-narrow r-lists reveal">
    <div class="r-group">
      <span class="eyebrow flanked">To read</span>
      <ul class="r-list">
        {books.map((b) => (
          <li><span class="r-title">{b.t}</span> <span class="r-by">· {b.a}</span><span class="r-desc">{b.d}</span></li>
        ))}
      </ul>
    </div>

    <Divider />

    <div class="r-group">
      <span class="eyebrow flanked">To watch</span>
      <ul class="r-list">
        {watch.map((w) => (
          <li><a class="r-title link" href={w.href} target="_blank" rel="noopener">{w.t} ↗</a><span class="r-desc">{w.d}</span></li>
        ))}
      </ul>
    </div>

    <Divider />

    <div class="r-group">
      <span class="eyebrow flanked">To listen</span>
      <ul class="r-list">
        {listen.map((l) => (
          <li><a class="r-title link" href={l.href} target="_blank" rel="noopener">{l.t} ↗</a><span class="r-desc">{l.d}</span></li>
        ))}
      </ul>
    </div>

    <Divider />

    <div class="r-group">
      <span class="eyebrow flanked">Online</span>
      <ul class="r-list">
        {online.map((o) => (
          <li><a class="r-title link" href={o.href} target="_blank" rel="noopener">{o.t} ↗</a><span class="r-desc">{o.d}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- dhams / yatra -->
  <section class="shell-narrow r-dhams reveal">
    <Divider />
    <div class="dhams-card card">
      <span class="eyebrow">Dhams &amp; pilgrimage</span>
      <h2>Visit his dhams</h2>
      <p>Maharaj-ji’s ashrams stand across India and beyond — Kainchi, Vrindavan, Rishikesh, Taos. Planning the journey to <strong>Kainchi Dham</strong>? We’ve put together a practical guide.</p>
      <div class="dhams-actions">
        <a href="/yatra/" class="btn btn-primary">Yatra to Kainchi →</a>
        <a href="/people/" class="link-gold">The people around him →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .r-chalisa { padding: 1.5rem 0; }
  .rc-card { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; padding: 2.2rem; background: linear-gradient(160deg, color-mix(in srgb, var(--color-maroon) 10%, var(--color-paper-warm)), var(--color-paper-warm)); }
  .rc-card h2 { font-size: 1.8rem; color: var(--color-maroon); margin: 0.3rem 0 0.4rem; }
  .rc-card p { color: var(--color-ink-soft); }

  .r-lists { padding: 1.5rem 0; }
  .r-group { padding: 0.5rem 0; }
  .r-group .eyebrow { display: inline-flex; margin-bottom: 1.1rem; }
  .r-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.1rem; }
  .r-list li { display: grid; gap: 0.15rem; padding-left: 1.1rem; border-left: 2px solid color-mix(in srgb, var(--color-gold) 40%, transparent); }
  .r-title { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; color: var(--color-ink); }
  .r-title.link { color: var(--color-maroon); transition: color 0.25s var(--ease-soft); }
  .r-title.link:hover { color: var(--color-maroon-deep); }
  .r-by { font-family: var(--font-ui); font-size: 0.85rem; color: var(--color-ink-faint); }
  .r-desc { color: var(--color-ink-soft); font-size: 0.98rem; }

  .r-dhams { padding: 1rem 0 2rem; }
  .dhams-card { padding: 2.2rem; text-align: center; background: linear-gradient(160deg, color-mix(in srgb, var(--color-gold) 12%, var(--color-paper-warm)), var(--color-paper-warm)); }
  .dhams-card .eyebrow { display: inline-flex; margin-bottom: 0.6rem; }
  .dhams-card h2 { font-size: 1.7rem; margin-bottom: 0.6rem; }
  .dhams-card p { color: var(--color-ink-soft); max-width: 40rem; margin: 0 auto 1.4rem; }
  .dhams-actions { display: flex; align-items: center; justify-content: center; gap: 1.4rem; flex-wrap: wrap; }
</style>
