---
// A faint geometric mandala — used as an atmospheric watermark behind sections.
interface Props { size?: number; class?: string; spin?: boolean; }
const { size = 480, class: cls = '', spin = false } = Astro.props;
const petals = Array.from({ length: 16 });
---

<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 200 200"
  fill="none"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <g class={spin ? 'spin-slow' : ''} stroke="currentColor" stroke-width="0.6" fill="none">
    <circle cx="100" cy="100" r="96" />
    <circle cx="100" cy="100" r="78" />
    <circle cx="100" cy="100" r="46" stroke-dasharray="2 3" />
    <circle cx="100" cy="100" r="22" />
    {petals.map((_, i) => (
      <g transform={`rotate(${(360 / petals.length) * i} 100 100)`}>
        <path d="M100 22 C112 52 112 70 100 88 C88 70 88 52 100 22 Z" />
        <circle cx="100" cy="14" r="2.4" fill="currentColor" stroke="none" />
      </g>
    ))}
    {Array.from({ length: 8 }).map((_, i) => (
      <line
        x1="100" y1="54" x2="100" y2="78"
        transform={`rotate(${45 * i} 100 100)`}
      />
    ))}
  </g>
</svg>
