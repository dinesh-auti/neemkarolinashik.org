---
// A quiet hairline separator with a small centred diamond.
// Carries its own vertical spacing (parent scoped styles can't reach it).
interface Props { class?: string; }
const { class: cls = '' } = Astro.props;
---

<div class={`rule-diamond divider ${cls}`} aria-hidden="true"><span class="rd-mark">✦</span></div>

<style>
  .divider { margin-block: 3.25rem; }
  .rd-mark { color: var(--color-gold); font-size: 0.8rem; }
</style>
