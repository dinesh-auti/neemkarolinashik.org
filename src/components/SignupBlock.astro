---
import { CONNECT } from '../site.ts';
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---

<div class={`signup ${compact ? 'is-compact' : ''}`}>
  <div class="signup-card card">
    <div class="signup-whatsapp">
      <span class="eyebrow">Stay close</span>
      <h3>Join the WhatsApp community</h3>
      <p>Quiet reminders for the Tuesday aarti and word of any gathering. No noise — only satsang.</p>
      <a href={CONNECT.whatsapp} target="_blank" rel="noopener" class="btn btn-primary wa-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.8 14.2c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5-4.5-.2-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.4.7-.4h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.5-.3.3c-.1.1-.3.3-.1.6.1.3.7 1.1 1.4 1.8.9.8 1.7 1.1 2 1.2.2.1.4.1.6-.1l.8-1c.2-.2.4-.2.6-.1l1.9.9c.2.1.4.2.4.3.1.2.1.6 0 .9Z"/></svg>
        Join on WhatsApp
      </a>
    </div>

    <div class="signup-divider" aria-hidden="true"></div>

    <div class="signup-news">
      <span class="eyebrow">By post</span>
      <h3>Or leave your email</h3>
      <p>We’ll write only when something matters — a special bhandara, a satsang, a milestone toward our dham.</p>
      <form class="news-form">
        <input type="hidden" name="_subject" value="New email signup — Nashik satsang" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <label class="sr-only" for="news-email">Email address</label>
        <input id="news-email" type="email" name="email" placeholder="you@example.com" required />
        <button type="submit" class="btn btn-ghost">Keep me posted</button>
      </form>
      <p class="news-fine">Ram Ram. We’ll never share your details.</p>
      <p class="news-done deva" hidden>राम राम — you’re on the list. We’ll write only when it matters.</p>
    </div>
  </div>
</div>

<script define:vars={{ endpoint: CONNECT.formEndpoint }}>
  document.querySelectorAll('.news-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      const label = btn.textContent;
      btn.disabled = true; btn.textContent = 'Sending…';
      try {
        const res = await fetch(endpoint, {
          method: 'POST', headers: { Accept: 'application/json' }, body: new FormData(form),
        });
        if (!res.ok) throw new Error();
        const box = form.parentElement;
        form.hidden = true;
        const fine = box.querySelector('.news-fine'); if (fine) fine.hidden = true;
        const done = box.querySelector('.news-done'); if (done) done.hidden = false;
      } catch {
        btn.disabled = false; btn.textContent = label;
        alert('Something went wrong — please try again.');
      }
    });
  });
</script>

<style>
  .signup { position: relative; z-index: 1; }
  .signup-card { display: grid; grid-template-columns: 1fr; gap: 2rem; padding: 2.2rem; }
  .signup h3 { font-size: 1.45rem; margin: 0.5rem 0 0.6rem; }
  .signup p { color: var(--color-ink-soft); font-size: 0.98rem; max-width: 26rem; }
  .wa-btn { margin-top: 1.2rem; }
  .signup-divider { display: none; }
  .news-form { display: flex; gap: 0.6rem; margin-top: 1.2rem; flex-wrap: wrap; }
  .news-form input[type="email"] {
    flex: 1; min-width: 12rem; padding: 0.8rem 1rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-ink) 20%, transparent);
    background: var(--color-paper); font-family: var(--font-body); font-size: 0.95rem; color: var(--color-ink);
  }
  .news-form input:focus { border-color: var(--color-saffron); outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-saffron) 22%, transparent); }
  .news-fine { font-size: 0.78rem; color: var(--color-ink-faint); margin-top: 0.7rem; }
  .news-done { margin-top: 1rem; font-size: 1.05rem; color: var(--color-maroon); }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
  @media (min-width: 760px) {
    .signup-card { grid-template-columns: 1fr 1px 1fr; gap: 2.6rem; align-items: start; }
    .signup-divider { display: block; background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--color-gold) 50%, transparent), transparent); }
  }
</style>
