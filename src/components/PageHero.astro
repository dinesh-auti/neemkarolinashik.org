---
import Mandala from './Mandala.astro';
interface Props { eyebrow?: string; title: string; deva?: string; lede?: string; }
const { eyebrow, title, deva, lede } = Astro.props;
---

<header class="page-hero">
  <div class="ph-mandala" aria-hidden="true"><Mandala size={520} /></div>
  <div class="shell-narrow ph-inner reveal">
    {deva && <p class="ph-deva deva">{deva}</p>}
    {eyebrow && <span class="eyebrow flanked">{eyebrow}</span>}
    <h1 class="ph-title">{title}</h1>
    {lede && <p class="ph-lede">{lede}</p>}
  </div>
</header>

<style>
  .page-hero { position: relative; overflow: hidden; padding: 3.5rem 0 1.5rem; text-align: center; }
  .ph-mandala { position: absolute; top: -38%; left: 50%; transform: translateX(-50%); color: var(--color-gold); opacity: 0.1; pointer-events: none; }
  .ph-inner { position: relative; z-index: 2; }
  .ph-deva { font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--color-maroon); margin-bottom: 0.6rem; }
  .page-hero .eyebrow { display: inline-flex; margin-bottom: 1rem; }
  .ph-title { font-size: clamp(2.2rem, 6vw, 3.6rem); font-style: italic; font-weight: 400; }
  .ph-lede { font-size: 1.15rem; color: var(--color-ink-soft); margin-top: 1.2rem; max-width: 38rem; margin-inline: auto; }
</style>
