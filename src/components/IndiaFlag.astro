---
// The Indian tricolour with a simplified Ashoka Chakra. SVG so it renders
// consistently everywhere (the 🇮🇳 emoji shows as "IN" on Windows).
interface Props { size?: number; class?: string; }
const { size = 22, class: cls = '' } = Astro.props;
const spokes = Array.from({ length: 24 });
---

<svg class={cls} width={size} height={(size * 2) / 3} viewBox="0 0 36 24" role="img" aria-label="India" xmlns="http://www.w3.org/2000/svg">
  <rect width="36" height="24" rx="2.5" fill="#fff" />
  <path d="M2.5 0H33.5A2.5 2.5 0 0 1 36 2.5V8H0V2.5A2.5 2.5 0 0 1 2.5 0Z" fill="#FF9933" />
  <path d="M0 16H36V21.5A2.5 2.5 0 0 1 33.5 24H2.5A2.5 2.5 0 0 1 0 21.5V16Z" fill="#138808" />
  <g stroke="#000080" stroke-width="0.35">
    <circle cx="18" cy="12" r="3.05" fill="none" />
    {spokes.map((_, i) => (
      <line x1="18" y1="12" x2="18" y2="8.95" transform={`rotate(${i * 15} 18 12)`} />
    ))}
  </g>
  <circle cx="18" cy="12" r="0.7" fill="#000080" />
  <rect x="0.25" y="0.25" width="35.5" height="23.5" rx="2.4" fill="none" stroke="rgba(0,0,0,0.12)" stroke-width="0.5" />
</svg>
